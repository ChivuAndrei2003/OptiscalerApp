<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="OptiscalerApp.App"
             xmlns:local="using:OptiscalerApp"
             RequestedThemeVariant="Default">
    <!-- "Default" ThemeVariant follows system theme variant. "Dark" or "Light" are other available options. -->

    <Application.Resources>
        <ResourceDictionary>
            
            <Color x:Key="BgDeepColor">#0E0E1A</Color>
            <Color x:Key="BgBaseColor">#13131F</Color>
            <Color x:Key="BgSurfaceColor">#1C1C2E</Color>
            <Color x:Key="BgCardColor">#1E1E30</Color>
            <Color x:Key="BgElevatedColor">#252540</Color>
            <Color x:Key="BorderSubtleColor">#2A2A42</Color>
            <Color x:Key="BorderDefaultColor">#363660</Color>
            <Color x:Key="AccentPrimaryColor">#8B73F8</Color>
            <Color x:Key="AccentPrimaryHoverColor">#9D88FF</Color>
            <Color x:Key="AccentPrimaryPressedColor">#7560E0</Color>
            <Color x:Key="AccentWarmColor">#F0834A</Color>
            <Color x:Key="AccentWarmHoverColor">#F59560</Color>
            <Color x:Key="TextPrimaryColor">#E4E4EF</Color>
            <Color x:Key="TextSecondaryColor">#8A8AAA</Color>
            <Color x:Key="TextDisabledColor">#4A4A65</Color>
            <Color x:Key="StatusSuccessColor">#5CB87E</Color>
            <Color x:Key="StatusErrorColor">#E06060</Color>
            <Color x:Key="StatusWarningColor">#D4A04A</Color>

            <SolidColorBrush x:Key="BrBgDeep" Color="{StaticResource BgDeepColor}" />
            <SolidColorBrush x:Key="BrBgBase" Color="{StaticResource BgBaseColor}" />
            <SolidColorBrush x:Key="BrBgSurface" Color="{StaticResource BgSurfaceColor}" />
            <SolidColorBrush x:Key="BrBgCard" Color="{StaticResource BgCardColor}" />
            <SolidColorBrush x:Key="BrBgElevated" Color="{StaticResource BgElevatedColor}" />
            <SolidColorBrush x:Key="BrBorderSubtle" Color="{StaticResource BorderSubtleColor}" />
            <SolidColorBrush x:Key="BrBorderDefault" Color="{StaticResource BorderDefaultColor}" />
            <SolidColorBrush x:Key="BrAccent" Color="{StaticResource AccentPrimaryColor}" />
            <SolidColorBrush x:Key="BrAccentHover" Color="{StaticResource AccentPrimaryHoverColor}" />
            <SolidColorBrush x:Key="BrAccentPressed" Color="{StaticResource AccentPrimaryPressedColor}" />
            <SolidColorBrush x:Key="BrAccentWarm" Color="{StaticResource AccentWarmColor}" />
            <SolidColorBrush x:Key="BrAccentWarmHover" Color="{StaticResource AccentWarmHoverColor}" />
            <SolidColorBrush x:Key="BrTextPrimary" Color="{StaticResource TextPrimaryColor}" />
            <SolidColorBrush x:Key="BrTextSecondary" Color="{StaticResource TextSecondaryColor}" />
            <SolidColorBrush x:Key="BrTextDisabled" Color="{StaticResource TextDisabledColor}" />
            <SolidColorBrush x:Key="BrSuccess" Color="{StaticResource StatusSuccessColor}" />
            <SolidColorBrush x:Key="BrError" Color="{StaticResource StatusErrorColor}" />
            <SolidColorBrush x:Key="BrWarning" Color="{StaticResource StatusWarningColor}" />

            <FontFamily x:Key="FontPrimary">Segoe UI Variable, Segoe UI, sans-serif</FontFamily>
            <FontFamily x:Key="FontIcons">avares://OptiscalerClient/assets/FluentSystemIcons-Regular.ttf#FluentSystemIcons-Regular, Segoe Fluent Icons, Segoe MDL2 Assets</FontFamily>
            <FontFamily x:Key="FontIconsFilled">avares://OptiscalerClient/assets/FluentSystemIcons-Filled.ttf#FluentSystemIcons-Filled</FontFamily>
            <x:Double x:Key="FontSizeCaption">11</x:Double>
            <x:Double x:Key="FontSizeBody">13</x:Double>
            <x:Double x:Key="FontSizeBodyLarge">15</x:Double>
            <x:Double x:Key="FontSizeSubtitle">18</x:Double>
            <x:Double x:Key="FontSizeTitle">22</x:Double>

            <CornerRadius x:Key="RadiusSmall">4</CornerRadius>
            <CornerRadius x:Key="RadiusMedium">8</CornerRadius>
            <CornerRadius x:Key="RadiusLarge">12</CornerRadius>
            <CornerRadius x:Key="RadiusXi">16</CornerRadius>
            <CornerRadius x:Key="RadiusPill">50</CornerRadius>

            <!-- Override FluentTheme default Resource Dictionary keys for ComboBox -->
            <SolidColorBrush x:Key="ComboBoxBackground" Color="{StaticResource BgSurfaceColor}" />
            <SolidColorBrush x:Key="ComboBoxBackgroundPointerOver" Color="{StaticResource BgSurfaceColor}" />
            <SolidColorBrush x:Key="ComboBoxBackgroundPressed" Color="{StaticResource BgElevatedColor}" />
            <SolidColorBrush x:Key="ComboBoxBackgroundDisabled" Color="{StaticResource BgBaseColor}" />
            <SolidColorBrush x:Key="ComboBoxBorderBrush" Color="{StaticResource BorderSubtleColor}" />
            <SolidColorBrush x:Key="ComboBoxBorderBrushPointerOver" Color="{StaticResource AccentPrimaryColor}" />
            <SolidColorBrush x:Key="ComboBoxBorderBrushPressed" Color="{StaticResource AccentPrimaryPressedColor}" />
            <SolidColorBrush x:Key="ComboBoxDropDownBackground" Color="{StaticResource BgCardColor}" />
            <SolidColorBrush x:Key="ComboBoxDropDownBorderBrush" Color="{StaticResource BorderDefaultColor}" />
            <SolidColorBrush x:Key="ComboBoxItemBackgroundSelected" Color="{StaticResource AccentPrimaryColor}" />
            <SolidColorBrush x:Key="ComboBoxItemBackgroundPointerOver" Color="{StaticResource BgElevatedColor}" />
            <!-- End overrides -->
        </ResourceDictionary>
    </Application.Resources>
    <Application.DataTemplates>
        <local:ViewLocator />
    </Application.DataTemplates>

    <Application.Styles>
        <FluentTheme />
    </Application.Styles>
</Application>