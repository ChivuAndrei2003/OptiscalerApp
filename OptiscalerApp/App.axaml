<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="OptiscalerApp.App"
             xmlns:local="using:OptiscalerApp"
             RequestedThemeVariant="Light">

    <Application.Resources>
        <ResourceDictionary>
            <SolidColorBrush x:Key="AppBackgroundBrush" Color="#F5F6F8" />
            <SolidColorBrush x:Key="ShellBackgroundBrush" Color="#111317" />
            <SolidColorBrush x:Key="ShellSurfaceBrush" Color="#181B20" />
            <SolidColorBrush x:Key="SurfaceBrush" Color="#FFFFFF" />
            <SolidColorBrush x:Key="SurfaceMutedBrush" Color="#F0F2F5" />
            <SolidColorBrush x:Key="SurfacePressedBrush" Color="#E8ECF0" />
            <SolidColorBrush x:Key="BorderBrushSoft" Color="#D7DCE2" />
            <SolidColorBrush x:Key="BorderBrushStrong" Color="#AEB6C2" />
            <SolidColorBrush x:Key="TextBrush" Color="#171A20" />
            <SolidColorBrush x:Key="TextMutedBrush" Color="#66707E" />
            <SolidColorBrush x:Key="TextOnDarkBrush" Color="#F7F8FA" />
            <SolidColorBrush x:Key="TextOnDarkMutedBrush" Color="#AEB6C2" />
            <SolidColorBrush x:Key="AccentBrush" Color="#0F766E" />
            <SolidColorBrush x:Key="AccentSoftBrush" Color="#E3F4F1" />
            <SolidColorBrush x:Key="BlueAccentBrush" Color="#2563EB" />
            <SolidColorBrush x:Key="BlueSoftBrush" Color="#EAF1FF" />
            <SolidColorBrush x:Key="WarningBrush" Color="#B45309" />
            <SolidColorBrush x:Key="WarningSoftBrush" Color="#FFF3D7" />
            <SolidColorBrush x:Key="DangerBrush" Color="#B42318" />
            <SolidColorBrush x:Key="DangerSoftBrush" Color="#FEECEC" />
        </ResourceDictionary>
    </Application.Resources>

    <Application.DataTemplates>
        <local:ViewLocator />
    </Application.DataTemplates>

    <Application.Styles>
        <FluentTheme />

        <Style Selector="Window">
            <Setter Property="FontFamily" Value="Inter, Segoe UI, Arial" />
            <Setter Property="Background" Value="{StaticResource AppBackgroundBrush}" />
        </Style>

        <Style Selector="UserControl">
            <Setter Property="FontFamily" Value="Inter, Segoe UI, Arial" />
        </Style>

        <Style Selector="Button">
            <Setter Property="Padding" Value="12,8" />
            <Setter Property="MinHeight" Value="36" />
            <Setter Property="Background" Value="{StaticResource SurfaceBrush}" />
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushSoft}" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>

        <Style Selector="Button.primary">
            <Setter Property="Background" Value="{StaticResource AccentBrush}" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
        </Style>

        <Style Selector="Button.secondary">
            <Setter Property="Background" Value="{StaticResource SurfaceMutedBrush}" />
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushSoft}" />
        </Style>

        <Style Selector="Button.ghost">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{StaticResource TextOnDarkMutedBrush}" />
            <Setter Property="BorderBrush" Value="Transparent" />
        </Style>

        <Style Selector="Button.ghost:pointerover">
            <Setter Property="Background" Value="{StaticResource ShellSurfaceBrush}" />
            <Setter Property="Foreground" Value="{StaticResource TextOnDarkBrush}" />
        </Style>

        <Style Selector="Button.danger">
            <Setter Property="Background" Value="{StaticResource DangerSoftBrush}" />
            <Setter Property="Foreground" Value="{StaticResource DangerBrush}" />
            <Setter Property="BorderBrush" Value="#F8B4B4" />
        </Style>

        <Style Selector="TextBox">
            <Setter Property="MinHeight" Value="36" />
            <Setter Property="Background" Value="{StaticResource SurfaceBrush}" />
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushSoft}" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>

        <Style Selector="ComboBox">
            <Setter Property="MinHeight" Value="36" />
            <Setter Property="Background" Value="{StaticResource SurfaceBrush}" />
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushSoft}" />
        </Style>

        <Style Selector="ComboBoxItem">
            <Setter Property="Background" Value="{StaticResource SurfaceBrush}" />
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
        </Style>

        <Style Selector="ComboBoxItem:pointerover">
            <Setter Property="Background" Value="{StaticResource SurfaceMutedBrush}" />
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
        </Style>

        <Style Selector="ComboBoxItem:selected">
            <Setter Property="Background" Value="{StaticResource AccentSoftBrush}" />
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
        </Style>

        <Style Selector="Border.card">
            <Setter Property="Background" Value="{StaticResource SurfaceBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushSoft}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="8" />
        </Style>

        <Style Selector="Border.softCard">
            <Setter Property="Background" Value="{StaticResource SurfaceMutedBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushSoft}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="8" />
        </Style>

        <Style Selector="TextBlock.h1">
            <Setter Property="FontSize" Value="24" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
        </Style>

        <Style Selector="TextBlock.h2">
            <Setter Property="FontSize" Value="18" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
        </Style>

        <Style Selector="TextBlock.label">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{StaticResource TextMutedBrush}" />
        </Style>

        <Style Selector="TextBlock.muted">
            <Setter Property="Foreground" Value="{StaticResource TextMutedBrush}" />
        </Style>
    </Application.Styles>
</Application>
