<Application xmlns = "https://github.com/avaloniaui"
             xmlns:x = "http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class = "OptiscalerApp.App"
             xmlns:local = "using:OptiscalerApp"
             RequestedThemeVariant = "Light">

    <Application.Resources>
        <ResourceDictionary>
            <Color x:Key = "BgDeepColor"> #0F100E </Color> <Color x:Key = "BgBaseColor"> #151613 </Color>
            <Color x:Key = "BgSurfaceColor"> #1A1B18 </Color> <Color x:Key = "BgCardColor"> #1A1B18 </Color>
            <Color x:Key = "BgElevatedColor"> #20211D </Color> <Color x:Key = "BorderSubtleColor"> #34352F </Color>
            <Color x:Key = "BorderDefaultColor"> #46473F </Color> <Color x:Key = "AccentColor"> #5FD2AD </Color>
            <Color x:Key = "AccentHoverColor"> #8BE3C2 </Color> <Color x:Key = "AccentPressedColor"> #46B996 </Color>
            <Color x:Key = "AccentWarmColor"> #EBCB7A </Color> <Color x:Key = "AccentWarmHoverColor"> #F2D994 </Color>
            <Color x:Key = "TextPrimaryColor"> #F2F0E8 </Color> <Color x:Key = "TextSecondaryColor"> #BCB5A6 </Color>
            <Color x:Key = "TextDisabledColor"> #6E6F64 </Color> <Color x:Key = "StatusSuccessColor"> #BDEB7C </Color>
            <Color x:Key = "StatusErrorColor"> #F18B8B </Color> <Color x:Key = "StatusWarningColor"> #EBCB7A </Color>
            <Color x:Key = "StatusInfoColor"> #8AB4F8 </Color> <Color x:Key = "StatusBetaColor"> #B69CFF </Color>

            <SolidColorBrush x:Key = "BrBgDeep"
                             Color = "{StaticResource BgDeepColor}" />
            <SolidColorBrush x:Key = "BrBgBase"
                             Color = "{StaticResource BgBaseColor}" />
            <SolidColorBrush x:Key = "BrBgSurface"
                             Color = "{StaticResource BgSurfaceColor}" />
            <SolidColorBrush x:Key = "BrBgCard"
                             Color = "{StaticResource BgCardColor}" />
            <SolidColorBrush x:Key = "BrBgElevated"
                             Color = "{StaticResource BgElevatedColor}" />
            <SolidColorBrush x:Key = "BrBorderSubtle"
                             Color = "{StaticResource BorderSubtleColor}" />
            <SolidColorBrush x:Key = "BrBorderDefault"
                             Color = "{StaticResource BorderDefaultColor}" />
            <SolidColorBrush x:Key = "BrAccent"
                             Color = "{StaticResource AccentColor}" />
            <SolidColorBrush x:Key = "BrAccentHover"
                             Color = "{StaticResource AccentHoverColor}" />
            <SolidColorBrush x:Key = "BrAccentPressed"
                             Color = "{StaticResource AccentPressedColor}" />
            <SolidColorBrush x:Key = "BrAccentWarm"
                             Color = "{StaticResource AccentWarmColor}" />
            <SolidColorBrush x:Key = "BrAccentWarmHover"
                             Color = "{StaticResource AccentWarmHoverColor}" />
            <SolidColorBrush x:Key = "BrTextPrimary"
                             Color = "{StaticResource TextPrimaryColor}" />
            <SolidColorBrush x:Key = "BrTextSecondary"
                             Color = "{StaticResource TextSecondaryColor}" />
            <SolidColorBrush x:Key = "BrTextDisabled"
                             Color = "{StaticResource TextDisabledColor}" />
            <SolidColorBrush x:Key = "BrSuccess"
                             Color = "{StaticResource StatusSuccessColor}" />
            <SolidColorBrush x:Key = "BrError"
                             Color = "{StaticResource StatusErrorColor}" />
            <SolidColorBrush x:Key = "BrWarning"
                             Color = "{StaticResource StatusWarningColor}" />
            <SolidColorBrush x:Key = "BrInfo"
                             Color = "{StaticResource StatusInfoColor}" />
            <SolidColorBrush x:Key = "BrBeta"
                             Color = "{StaticResource StatusBetaColor}" />

            <SolidColorBrush x:Key = "BrAccentSubtle"
                             Color = "#173229" />
            <SolidColorBrush x:Key = "BrWarmSubtle"
                             Color = "#332B18" />
            <SolidColorBrush x:Key = "BrInfoSubtle"
                             Color = "#172439" />
            <SolidColorBrush x:Key = "BrErrorSubtle"
                             Color = "#351D1D" />
            <SolidColorBrush x:Key = "BrSuccessSubtle"
                             Color = "#243118" />

            <SolidColorBrush x:Key = "AppBackgroundBrush"
                             Color = "{StaticResource BgBaseColor}" />
            <SolidColorBrush x:Key = "ShellBackgroundBrush"
                             Color = "{StaticResource BgDeepColor}" />
            <SolidColorBrush x:Key = "ShellSurfaceBrush"
                             Color = "{StaticResource BgSurfaceColor}" />
            <SolidColorBrush x:Key = "SurfaceBrush"
                             Color = "{StaticResource BgCardColor}" />
            <SolidColorBrush x:Key = "SurfaceMutedBrush"
                             Color = "{StaticResource BgElevatedColor}" />
            <SolidColorBrush x:Key = "SurfacePressedBrush"
                             Color = "#272820" />
            <SolidColorBrush x:Key = "BorderBrushSoft"
                             Color = "{StaticResource BorderSubtleColor}" />
            <SolidColorBrush x:Key = "BorderBrushStrong"
                             Color = "{StaticResource BorderDefaultColor}" />
            <SolidColorBrush x:Key = "TextBrush"
                             Color = "{StaticResource TextPrimaryColor}" />
            <SolidColorBrush x:Key = "TextMutedBrush"
                             Color = "{StaticResource TextSecondaryColor}" />
            <SolidColorBrush x:Key = "TextOnDarkBrush"
                             Color = "{StaticResource TextPrimaryColor}" />
            <SolidColorBrush x:Key = "TextOnDarkMutedBrush"
                             Color = "{StaticResource TextSecondaryColor}" />
            <SolidColorBrush x:Key = "AccentBrush"
                             Color = "{StaticResource AccentColor}" />
            <SolidColorBrush x:Key = "AccentSoftBrush"
                             Color = "#173229" />
            <SolidColorBrush x:Key = "BlueAccentBrush"
                             Color = "{StaticResource StatusInfoColor}" />
            <SolidColorBrush x:Key = "BlueSoftBrush"
                             Color = "#172439" />
            <SolidColorBrush x:Key = "WarningBrush"
                             Color = "{StaticResource StatusWarningColor}" />
            <SolidColorBrush x:Key = "WarningSoftBrush"
                             Color = "#332B18" />
            <SolidColorBrush x:Key = "DangerBrush"
                             Color = "{StaticResource StatusErrorColor}" />
            <SolidColorBrush x:Key = "DangerSoftBrush"
                             Color = "#351D1D" />
        </ResourceDictionary>
    </Application.Resources>

    <Application.DataTemplates>
        <local:ViewLocator />
    </Application.DataTemplates>

    <Application.Styles>
        <FluentTheme />

        <Style Selector = "Window">
            <Setter Property = "FontFamily"
                    Value = "Inter, Segoe UI, Arial" />
            <Setter Property = "Background"
                    Value = "{DynamicResource BrBgDeep}" />
        </Style>

        <Style Selector = "UserControl">
            <Setter Property = "FontFamily"
                    Value = "Inter, Segoe UI, Arial" />
            <Setter Property = "Background"
                    Value = "{DynamicResource BrBgBase}" />
        </Style>

        <Style Selector = "TextBlock">
            <Setter Property = "Foreground"
                    Value = "{DynamicResource BrTextPrimary}" />
            <Setter Property = "TextWrapping"
                    Value = "Wrap" />
        </Style>

        <Style Selector = "TextBlock.eyebrow">
            <Setter Property = "FontSize"
                    Value = "10" />
            <Setter Property = "FontWeight"
                    Value = "Bold" />
            <Setter Property = "Foreground"
                    Value = "{DynamicResource BrAccent}" />
        </Style>

        <Style Selector = "TextBlock.h1">
            <Setter Property = "FontSize"
                    Value = "26" />
            <Setter Property = "FontWeight"
                    Value = "SemiBold" />
            <Setter Property = "Foreground"
                    Value = "{DynamicResource BrTextPrimary}" />
        </Style>

        <Style Selector = "TextBlock.h2">
            <Setter Property = "FontSize"
                    Value = "18" />
            <Setter Property = "FontWeight"
                    Value = "SemiBold" />
            <Setter Property = "Foreground"
                    Value = "{DynamicResource BrTextPrimary}" />
        </Style>

        <Style Selector = "TextBlock.h3">
            <Setter Property = "FontSize"
                    Value = "14" />
            <Setter Property = "FontWeight"
                    Value = "SemiBold" />
            <Setter Property = "Foreground"
                    Value = "{DynamicResource BrTextPrimary}" />
        </Style>

        <Style Selector = "TextBlock.muted">
            <Setter Property = "Foreground"
                    Value = "{DynamicResource BrTextSecondary}" />
        </Style>

        <Style Selector = "TextBlock.caption">
            <Setter Property = "FontSize"
                    Value = "11" />
            <Setter Property = "Foreground"
                    Value = "{DynamicResource BrTextSecondary}" />
        </Style>

        <Style Selector = "TextBlock.mono">
            <Setter Property = "FontFamily"
                    Value = "SF Mono, Consolas, Menlo, monospace" />
            <Setter Property = "FontSize"
                    Value = "12" />
            <Setter Property = "Foreground"
                    Value = "{DynamicResource BrTextSecondary}" />
        </Style>

        <Style Selector = "Button">
            <Setter Property = "Padding"
                    Value = "12,8" />
            <Setter Property = "MinHeight"
                    Value = "36" />
            <Setter Property = "Background"
                    Value = "Transparent" />
            <Setter Property = "Foreground"
                    Value = "{DynamicResource BrTextPrimary}" />
            <Setter Property = "BorderBrush"
                    Value = "{DynamicResource BrBorderSubtle}" />
            <Setter Property = "BorderThickness"
                    Value = "1" />
            <Setter Property = "CornerRadius"
                    Value = "8" />
            <Setter Property = "HorizontalContentAlignment"
                    Value = "Center" />
            <Setter Property = "VerticalContentAlignment"
                    Value = "Center" />
        </Style>

        <Style Selector = "Button:pointerover">
            <Setter Property = "Background"
                    Value = "#272820" />
            <Setter Property = "BorderBrush"
                    Value = "{DynamicResource BrBorderDefault}" />
        </Style>

        <Style Selector = "Button.primary">
            <Setter Property = "Background"
                    Value = "{DynamicResource BrAccent}" />
            <Setter Property = "Foreground"
                    Value = "#0B1410" />
            <Setter Property = "BorderBrush"
                    Value = "{DynamicResource BrAccent}" />
        </Style>

        <Style Selector = "Button.primary:pointerover">
            <Setter Property = "Background"
                    Value = "{DynamicResource BrAccentHover}" />
            <Setter Property = "BorderBrush"
                    Value = "{DynamicResource BrAccentHover}" />
        </Style>

        <Style Selector = "Button.secondary">
            <Setter Property = "Background"
                    Value = "{DynamicResource BrBgSurface}" />
            <Setter Property = "Foreground"
                    Value = "{DynamicResource BrTextPrimary}" />
            <Setter Property = "BorderBrush"
                    Value = "{DynamicResource BrBorderDefault}" />
        </Style>

        <Style Selector = "Button.ghost">
            <Setter Property = "Background"
                    Value = "Transparent" />
            <Setter Property = "Foreground"
                    Value = "{DynamicResource BrTextSecondary}" />
            <Setter Property = "BorderBrush"
                    Value = "Transparent" />
        </Style>

        <Style Selector = "Button.ghost:pointerover">
            <Setter Property = "Background"
                    Value = "{DynamicResource BrBgElevated}" />
            <Setter Property = "Foreground"
                    Value = "{DynamicResource BrTextPrimary}" />
        </Style>

        <Style Selector = "Button.danger">
            <Setter Property = "Background"
                    Value = "{DynamicResource BrErrorSubtle}" />
            <Setter Property = "Foreground"
                    Value = "{DynamicResource BrError}" />
            <Setter Property = "BorderBrush"
                    Value = "#633434" />
        </Style>

        <Style Selector = "Button.nav">
            <Setter Property = "Background"
                    Value = "Transparent" />
            <Setter Property = "BorderBrush"
                    Value = "Transparent" />
            <Setter Property = "HorizontalContentAlignment"
                    Value = "Stretch" />
            <Setter Property = "Padding"
                    Value = "12,10" />
            <Setter Property = "MinHeight"
                    Value = "44" />
        </Style>

        <Style Selector = "Button.nav:pointerover">
            <Setter Property = "Background"
                    Value = "{DynamicResource BrBgElevated}" />
            <Setter Property = "BorderBrush"
                    Value = "{DynamicResource BrBorderSubtle}" />
        </Style>

        <Style Selector = "Button.nav.active">
            <Setter Property = "Background"
                    Value = "{DynamicResource BrAccentSubtle}" />
            <Setter Property = "BorderBrush"
                    Value = "{DynamicResource BrAccent}" />
        </Style>

        <Style Selector = "Button.nav TextBlock">
            <Setter Property = "Foreground"
                    Value = "{DynamicResource BrTextSecondary}" />
        </Style>

        <Style Selector = "Button.nav.active TextBlock">
            <Setter Property = "Foreground"
                    Value = "{DynamicResource BrTextPrimary}" />
        </Style>

        <Style Selector = "Button.icon">
            <Setter Property = "Width"
                    Value = "36" />
            <Setter Property = "Height"
                    Value = "36" />
            <Setter Property = "Padding"
                    Value = "0" />
        </Style>

        <Style Selector = "Grid.appRoot">
            <Setter Property = "Background"
                    Value = "{DynamicResource BrBgBase}" />
        </Style>

        <Style Selector = "Grid.topbar">
            <Setter Property = "Height"
                    Value = "56" />
            <Setter Property = "Background"
                    Value = "{DynamicResource BrBgDeep}" />
        </Style>

        <Style Selector = "Grid.sidebar">
            <Setter Property = "Background"
                    Value = "{DynamicResource BrBgDeep}" />
            <Setter Property = "Margin"
                    Value = "8" />
        </Style>

        <Style Selector = "Grid.pageHost">
            <Setter Property = "Background"
                    Value = "{DynamicResource BrBgBase}" />
        </Style>

        <Style Selector = "Border.pageToolbar">
            <Setter Property = "Background"
                    Value = "{DynamicResource BrBgSurface}" />
            <Setter Property = "BorderBrush"
                    Value = "{DynamicResource BrBorderSubtle}" />
            <Setter Property = "BorderThickness"
                    Value = "0,0,0,1" />
            <Setter Property = "Padding"
                    Value = "18,12" />
        </Style>

        <Style Selector = "TextBlock.toolbarLabel">
            <Setter Property = "Foreground"
                    Value = "{DynamicResource BrTextSecondary}" />
            <Setter Property = "VerticalAlignment"
                    Value = "Center" />
        </Style>

        <Style Selector = "Border.gameCard">
            <Setter Property = "Width"
                    Value = "180" />
            <Setter Property = "Height"
                    Value = "230" />
            <Setter Property = "Margin"
                    Value = "0,0,16,16" />
            <Setter Property = "Padding"
                    Value = "12" />
            <Setter Property = "Background"
                    Value = "{DynamicResource BrBgCard}" />
            <Setter Property = "BorderBrush"
                    Value = "{DynamicResource BrBorderSubtle}" />
            <Setter Property = "BorderThickness"
                    Value = "1" />
            <Setter Property = "CornerRadius"
                    Value = "8" />
        </Style>

        <Style Selector = "Border.gameCover">
            <Setter Property = "Height"
                    Value = "120" />
            <Setter Property = "Background"
                    Value = "{DynamicResource BrBgElevated}" />
            <Setter Property = "CornerRadius"
                    Value = "6" />
        </Style>

        <Style Selector = "Border.gameCover.accent">
            <Setter Property = "Background"
                    Value = "{DynamicResource BrAccentSubtle}" />
        </Style>

        <Style Selector = "TextBox">
            <Setter Property = "MinHeight"
                    Value = "36" />
            <Setter Property = "Background"
                    Value = "{DynamicResource BrBgSurface}" />
            <Setter Property = "Foreground"
                    Value = "{DynamicResource BrTextPrimary}" />
            <Setter Property = "BorderBrush"
                    Value = "{DynamicResource BrBorderSubtle}" />
            <Setter Property = "BorderThickness"
                    Value = "1" />
            <Setter Property = "CornerRadius"
                    Value = "8" />
            <Setter Property = "Padding"
                    Value = "12,8" />
        </Style>

        <Style Selector = "ComboBox">
            <Setter Property = "MinHeight"
                    Value = "36" />
            <Setter Property = "Background"
                    Value = "{DynamicResource BrBgSurface}" />
            <Setter Property = "Foreground"
                    Value = "{DynamicResource BrTextPrimary}" />
            <Setter Property = "BorderBrush"
                    Value = "{DynamicResource BrBorderSubtle}" />
            <Setter Property = "CornerRadius"
                    Value = "8" />
        </Style>

        <Style Selector = "ComboBoxItem">
            <Setter Property = "Background"
                    Value = "{DynamicResource BrBgSurface}" />
            <Setter Property = "Foreground"
                    Value = "{DynamicResource BrTextPrimary}" />
        </Style>

        <Style Selector = "ComboBoxItem:pointerover">
            <Setter Property = "Background"
                    Value = "{DynamicResource BrBgElevated}" />
            <Setter Property = "Foreground"
                    Value = "{DynamicResource BrTextPrimary}" />
        </Style>

        <Style Selector = "ComboBoxItem:selected">
            <Setter Property = "Background"
                    Value = "{DynamicResource BrAccentSubtle}" />
            <Setter Property = "Foreground"
                    Value = "{DynamicResource BrTextPrimary}" />
        </Style>

        <Style Selector = "ToggleButton.segment">
            <Setter Property = "Background"
                    Value = "Transparent" />
            <Setter Property = "BorderBrush"
                    Value = "Transparent" />
            <Setter Property = "MinHeight"
                    Value = "32" />
            <Setter Property = "Padding"
                    Value = "10,6" />
        </Style>

        <Style Selector = "ToggleButton.segment:checked">
            <Setter Property = "Background"
                    Value = "{DynamicResource BrAccentSubtle}" />
            <Setter Property = "BorderBrush"
                    Value = "{DynamicResource BrAccent}" />
            <Setter Property = "Foreground"
                    Value = "{DynamicResource BrTextPrimary}" />
        </Style>

        <Style Selector = "Border.card">
            <Setter Property = "Background"
                    Value = "{DynamicResource BrBgCard}" />
            <Setter Property = "BorderBrush"
                    Value = "{DynamicResource BrBorderSubtle}" />
            <Setter Property = "BorderThickness"
                    Value = "1" />
            <Setter Property = "CornerRadius"
                    Value = "12" />
        </Style>

        <Style Selector = "Border.panel">
            <Setter Property = "Background"
                    Value = "{DynamicResource BrBgSurface}" />
            <Setter Property = "BorderBrush"
                    Value = "{DynamicResource BrBorderSubtle}" />
            <Setter Property = "BorderThickness"
                    Value = "1" />
            <Setter Property = "CornerRadius"
                    Value = "12" />
        </Style>

        <Style Selector = "Border.softCard">
            <Setter Property = "Background"
                    Value = "{DynamicResource BrBgElevated}" />
            <Setter Property = "BorderBrush"
                    Value = "{DynamicResource BrBorderSubtle}" />
            <Setter Property = "BorderThickness"
                    Value = "1" />
            <Setter Property = "CornerRadius"
                    Value = "10" />
        </Style>

        <Style Selector = "Border.pill">
            <Setter Property = "Background"
                    Value = "{DynamicResource BrBgElevated}" />
            <Setter Property = "BorderBrush"
                    Value = "{DynamicResource BrBorderSubtle}" />
            <Setter Property = "BorderThickness"
                    Value = "1" />
            <Setter Property = "CornerRadius"
                    Value = "999" />
            <Setter Property = "Padding"
                    Value = "8,3" />
        </Style>

        <Style Selector = "ProgressBar">
            <Setter Property = "Foreground"
                    Value = "{DynamicResource BrAccent}" />
            <Setter Property = "Background"
                    Value = "{DynamicResource BrBgDeep}" />
            <Setter Property = "MinHeight"
                    Value = "6" />
        </Style>
    </Application.Styles>
</Application>
