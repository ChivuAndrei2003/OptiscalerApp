{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "build OptiscalerApp",
            "type": "process",
            "command": "dotnet",
            "args": [
                "build",
                "${workspaceFolder}/OptiscalerApp/OptiscalerApp.csproj"
            ],
            "options": {
                "env": {
                    "AVALONIA_TELEMETRY_OPTOUT": "1"
                }
            },
            "problemMatcher": "$msCompile",
            "group": "build"
        },
        {
            "label": "run OptiscalerApp",
            "type": "process",
            "command": "dotnet",
            "args": [
                "run",
                "--project",
                "${workspaceFolder}/OptiscalerApp/OptiscalerApp.csproj"
            ],
            "options": {
                "env": {
                    "AVALONIA_TELEMETRY_OPTOUT": "1"
                }
            },
            "problemMatcher": "$msCompile",
            "group": {
                "kind": "test",
                "isDefault": true
            }
        }
    ]
}
